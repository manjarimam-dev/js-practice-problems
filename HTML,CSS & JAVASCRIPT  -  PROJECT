/* Purane .card aur uske andar ke elements ko isse replace karo */

.card {
    background-color: black; /* Ek dum mast dark-theme card background */
    color: white;
    margin: 40px auto;        /* Screen ke bilkul center mein lane ke liye */
    display: flex;
    flex-direction: column;   /* THE FIX: Isse saare elements ek ke neeche ek aayenge */
    align-items: center;      /* Saari cheezon ko horizontally center karega */
    text-align: center;
    border-radius: 15px;      /* Sharp edges ki jagah smooth premium rounded corners */
    box-shadow: 0 16px 132px rgba(0, 255, 255, 0.4); /* Piche ek solid shadow effect */
    width: 320px;
    padding: 25px 15px;       /* Fixed height hata di taaki content ke hisab se card adjust ho */
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

/* Image ko ekdum perfect gol aur border dene ke liye */
.card img {
    width: 130px;
    height: 130px;            /* Height-width same rakhne se circle perfect banega */
    border-radius: 50%;
    /* object-fit: cover; */
    border: 3px solid #00ff66; /* Ek cool green hacker-style border */
    margin-bottom: 15px;
}

/* Name heading ke liye */
.card h2 {
    font-size: 22px;
    margin-bottom: 8px;
    letter-spacing: 0.5px;
}

/* Bio text ke liye */
.card p {
    color: #b3b3b3;
    font-size: 14px;
    margin-bottom: 15px;
    line-height: 1.4;
}

/* Followers section ke liye */
.card h4 {
    background-color: #2a2a35;
    padding: 6px 15px;
    border-radius: 20px;
    font-size: 14px;
    color: #00ff66;
}










      //    JAVASCRIPT CODE HERE   //



const inputarea = document.getElementById("user");
const clickbtn = document.querySelector(".search");
const  khalicard = document.querySelector(".card");

// user ka input Lo
clickbtn.addEventListener("click", async ()=>{
// user ka name direct Lo 

const username = inputarea.value

 const response = await fetch(`https://api.github.com/users/${username}`);
 let data = await response.json()
 console.log(data)

 khalicard.innerHTML = `
 <img src="${data.avatar_url}" width = "150px"; style = "border-radius:50%; margin-top:20px;" >
 <h2>${data.name || data.login}</h2>
 <p>${data.bio || "bio not available"}</p>
 <h4>Followers: ${data.followers}</h4>
 `
})
